# API authentication
KYC_API_KEY=dev-secret
ADMIN_SECRET=admin-secret-change-me

# Database
DATABASE_URL=postgresql+asyncpg://verify:verify@localhost:5432/webank_verify

# Redis
REDIS_URL=redis://localhost:6379/0

# Webhook (BFF endpoint that receives events)
WEBHOOK_URL=http://localhost:8080/bff/v1/kyc/webhook
WEBHOOK_SECRET=webhook-hmac-secret-change-me

# GeoIP
GEOIP_DB_PATH=./data/GeoLite2-Country.mmdb
MAXMIND_LICENSE_KEY=

# S3-compatible storage (LocalStack in dev)
S3_ENDPOINT_URL=http://localhost:4566
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=webank-verify

# SMS (not used by this service — BFF handles OTP)
# SMS_GATEWAY_URL=

# Service config
PORT=8070
LOG_LEVEL=INFO
ENVIRONMENT=development
